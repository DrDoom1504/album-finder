# Backend configuration
DATABASE_URL=postgres://user:password@host:port/dbname
DATABASE_SSL=false
# If using SSL and a trusted CA, set to true. For self-signed testing, you may use false.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Spotify OAuth settings
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://your-domain.com/api/auth/callback

# Frontend origin for CORS and redirect handling
FRONTEND_URL=https://your-frontend-domain.com

# Cookie settings for production
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# Optional proxy support if deployed behind a reverse proxy
TRUST_PROXY=false
